PORT=3001
NODE_ENV=development

# 前端来源。多个来源用英文逗号分隔。
CORS_ORIGIN=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500,https://xuyannan0321.github.io

# JWT 密钥请在真实环境中使用长随机字符串，不要提交 .env。
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# 阿里云 RDS MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=math_ai_edu
DB_PASSWORD=replace-with-database-password
DB_NAME=math_ai_edu
DB_CONNECTION_LIMIT=10

# 第 1 天暂不接 OSS，仅为后续上传图片/PDF 预留配置。
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
