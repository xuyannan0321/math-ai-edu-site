PORT=3001
NODE_ENV=development

# 前端来源。多个来源用英文逗号分隔。
CORS_ORIGIN=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500,https://xuyannan0321.github.io

# JWT 密钥请在真实环境中使用长随机字符串，不要提交 .env。
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# 阿里云 RDS MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=math_ai_edu
DB_PASSWORD=replace-with-database-password
DB_NAME=math_ai_edu
DB_CONNECTION_LIMIT=10

# OSS 预留。本阶段图片识题使用 memory upload，不假装上传 OSS。
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# AI 调用限制
DAILY_AI_LIMIT=20
MAX_IMAGE_SIZE_MB=3

# DashScope / 阿里通义。真实 Key 只写入 server/.env，不要写进前端。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_VISION_MODEL=

# DeepSeek 官方接口，主要用于文字解题。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GPT / OpenAI，可配置官方或中转站 Base URL。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_VISION_MODEL=

# Gemini，可配置中转站 Base URL。
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=
GEMINI_VISION_MODEL=
